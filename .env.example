# Copy to .env locally. On pxxl.app set the same keys in Environment.

PORT=3000
NODE_ENV=production

# Site URL (password reset links, etc.)
FRONTEND_URL=https://electra-core-store.pxxl.click

# Same as FRONTEND_URL when one server serves UI + API + /auth/*
PUBLIC_URL=https://electra-core-store.pxxl.click

# Google OAuth — must match Google Cloud Console exactly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override if different from ${PUBLIC_URL}/auth/google/callback
# GOOGLE_CALLBACK_URL=https://electra-core-store.pxxl.click/auth/google/callback

MONGODB_URI=
# Optional: database name if not in the URI path
# MONGODB_DB=electracore

SESSION_SECRET=
# TRUST_PROXY=0
