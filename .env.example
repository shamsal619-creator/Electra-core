# Copy to .env locally. On pxxl.app set the same keys in Environment.

PORT=3000
NODE_ENV=production

# Site URL (password reset links, etc.)
FRONTEND_URL=https://electra-core-store.pxxl.click

# Same as FRONTEND_URL when one server serves UI + API + /auth/*
PUBLIC_URL=https://electra-core-store.pxxl.click

# Google OAuth — must match Google Cloud Console exactly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override if different from ${PUBLIC_URL}/auth/google/callback
# GOOGLE_CALLBACK_URL=https://electra-core-store.pxxl.click/auth/google/callback

# Firebase Admin credentials (recommended: put service account JSON path)
FIREBASE_SERVICE_ACCOUNT_JSON=./firebase-service-account.json
IMAGE_STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional (needed only if IMAGE_STORAGE_PROVIDER=firebase):
# FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Optional (only for one-time migration from old MongoDB):
# MONGODB_URI=
# MONGODB_DB=

# Or use raw values for Firebase service account instead of JSON file:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

SESSION_SECRET=
ADMIN_EMAILS=shamsal619@gmail.com
# TRUST_PROXY=0
